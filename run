#!/bin/bash

# --- Duinch Cinema Launcher ---

# Colors
BLUE='\033[0;34m'
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

# Required Variables
REQUIRED_VARS=(
    "TMDB_READ_ACCESS_TOKEN"
    "HOST_STORAGE_PATH"
)

validate_env() {
    local env_file=".env"
    local env_example=".env.example"
    
    if [ ! -f "$env_file" ]; then
        echo -e "${YELLOW}⚠️  .env file not found. Creating from example...${NC}"
        if [ -f "$env_example" ]; then
            cp "$env_example" "$env_file"
        else
            touch "$env_file"
        fi
    fi

    local missing=()
    for var in "${REQUIRED_VARS[@]}"; do
        # Check if variable is set and not empty in .env (or exported)
        local value=$(grep "^$var=" "$env_file" | cut -d'=' -f2-)
        if [ -z "$value" ]; then
            missing+=("$var")
        fi
    done

    if [ ${#missing[@]} -gt 0 ]; then
        echo -e "${YELLOW}📋 Missing required configuration. Please enter details:${NC}"
        for var in "${missing[@]}"; do
            read -p "Enter $var: " input
            # Update or append to .env
            if grep -q "^$var=" "$env_file"; then
                # Use a different delimiter for sed to handle paths/special chars
                sed -i.bak "s|^$var=.*|$var=$input|" "$env_file" && rm "${env_file}.bak"
            else
                echo "$var=$input" >> "$env_file"
            fi
        done
        echo -e "${GREEN}✅ .env updated successfully!${NC}"
    fi
}

init_environment() {
    echo -e "${BLUE}📦 Initializing Environment...${NC}"
    if [ ! -d "venv" ]; then
        python3 -m venv venv
    fi
    source venv/bin/activate
    python3 -m pip install -q --upgrade pip
    echo "[*] Installing Backend dependencies..."
    python3 -m pip install -q -r duinch-cinema/backend/requirements.txt
    
    echo "[*] Installing Downloader dependencies..."
    python3 -m pip install -q -r duinch-downloader/requirements.txt
    
    echo "[*] Installing Crawler dependencies..."
    python3 -m pip install -q -r duinch-crawler/miner/requirements.txt
    
    echo "[*] Installing Frontend dependencies..."
    cd duinch-cinema/frontend && npm install --silent && cd ../..
}

clear
echo -e "${CYAN}======================================${NC}"
echo -e "${CYAN}🎬  DUINCH CINEMA - UNIFIED LAUNCHER  ${NC}"
echo -e "${CYAN}======================================${NC}"

# Run validation before showing menu
validate_env

echo -e "Choose a service to launch:"
echo -e "  ${GREEN}1) Launch All${NC} (Frontend + Backend) [Default]"
echo -e "  2) Crawler Miner (Start Mining)"
echo -e "  3) Crawler Cooker (Process Raw Links)"
echo -e "  4) Clear Cache"
echo -e "  ${BLUE}5) Init Environment${NC} (Install dependencies)"
echo -e "  ${CYAN}6) Setup .env${NC} (From example)"
echo -e "  ${YELLOW}7) Exit${NC}"
echo -e "${CYAN}--------------------------------------${NC}"

read -p "Enter selection [1]: " choice
choice=${choice:-1}

case $choice in
    1)
        echo -e "${GREEN}🚀 Initializing and Launching Duinch Cinema Stack...${NC}"
        init_environment --auto
        bash scripts/start_all.sh
        ;;
    2)
        echo -e "${GREEN}⛏️ Starting Miner...${NC}"
        bash scripts/start_miner.sh
        ;;
    3)
        echo -e "${GREEN}🍳 Starting Cooker...${NC}"
        bash scripts/start_cooker.sh
        ;;
    4)
        bash scripts/clear_cache.sh
        ;;
    5)
        init_environment
        echo -e "${GREEN}✅ Environment Initialized Successfully!${NC}"
        ;;
    6)
        echo -e "${CYAN}📝 Setting up .env files...${NC}"
        if [ -f ".env.example" ]; then
            cp ".env.example" ".env"
            echo -e "${GREEN}✅ Created .env from example${NC}"
            echo -e "${YELLOW}⚠️  Running validation to fill details...${NC}"
            validate_env
        else
            echo -e "${RED}❌ Error: .env.example not found in root${NC}"
        fi
        ;;
    7)
        echo "Goodbye!"
        exit 0
        ;;
    *)
        echo -e "${RED}Invalid selection.${NC}"
        exit 1
        ;;
esac
