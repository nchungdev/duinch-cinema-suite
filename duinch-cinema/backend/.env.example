# MyJDownloader Credentials
MYJD_EMAIL=your_email@example.com
MYJD_PASSWORD=your_myjd_password

# The Movie Database (TMDB)
TMDB_READ_ACCESS_TOKEN=your_tmdb_read_access_token

# Storage Path on Host
# Ensure this directory exists on your machine
HOST_STORAGE_PATH=/path/to/your/downloads

# --- PostgreSQL Connection ---
# These are default values used in docker-compose.yml
# You can override them here if needed.
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus
POSTGRES_DB=nexus_db
POSTGRES_HOST=localhost # Use 'postgres' if running inside docker-compose network
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Cache Settings (Optional) ---
# Time-to-live in seconds
RAW_THREAD_TTL=86400 # 24 hours
